{
  "name": "1mcp",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "workspaces": [
    "packages/server",
    "packages/shared"
  ],
  "scripts": {
    "build": "pnpm run build:shared && pnpm run build:server && pnpm run build:widget",
    "build:shared": "pnpm --filter @onemcp/shared build",
    "build:server": "pnpm --filter 1mcp build",
    "build:widget": "pnpm --filter @onemcp/widget-react build",
    "dev": "pnpm --filter 1mcp-docs dev",
    "serve": "node scripts/dev-serve.js serve --no-ui",
    "dev:tmux": "bash scripts/tmux-dev.sh",
    "init": "node scripts/dev-serve.js init",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepare": "husky",
    "1mcp": "node packages/server/dist/cli/index.js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.2",
    "@types/node": "^22.0.0",
    "concurrently": "9.2.1",
    "dotenv": "17.2.3",
    "husky": "^9.1.7",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "ai": "5.0.100",
    "zod": "^3.23.8"
  }
}