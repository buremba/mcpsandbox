{
  "name": "1mcp",
  "version": "0.1.3",
  "description": "MCP server aggregator with sandboxed JavaScript execution using WASM & QuickJS",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "1mcp": "./dist/cli/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "javascript",
    "quickjs",
    "v8-isolates",
    "sandbox",
    "code-execution"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/buremba/1mcp"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:node": "tsc && node -e \"require('fs').copyFileSync('src/db/schema.sql', 'dist/db/schema.sql')\"",
    "build:worker": "tsc && esbuild dist/index.worker.js --bundle --outfile=dist/worker.js --format=esm --platform=browser --external:better-sqlite3",
    "dev": "tsx watch src/index.ts",
    "dev:node": "tsx watch src/index.node.ts",
    "start": "node dist/index.node.js",
    "start:node": "node dist/index.node.js",
    "deploy:cf": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t relay-mcp -f Dockerfile ../..",
    "docker:run": "docker run -p 3000:3000 -e ENCRYPTION_SECRET=dev-secret relay-mcp"
  },
  "dependencies": {
    "@onemcp/ai-sdk": "workspace:*",
    "@onemcp/shared": "workspace:*",
    "@hono/node-server": "^1.13.0",
    "archiver": "^7.0.1",
    "commander": "^12.0.0",
    "esbuild": "^0.24.0",
    "fflate": "^0.8.2",
    "hono": "^4.0.0",
    "ipaddr.js": "^2.2.0",
    "jose": "^5.2.0",
    "json-schema-to-typescript": "15.0.4",
    "kleur": "^4.1.5",
    "nanoid": "^5.0.0",
    "open": "^10.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "quickjs-emscripten": "^0.30.0",
    "tldts": "^6.1.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/archiver": "^6.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "wrangler": "^3.91.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.6.0"
  }
}