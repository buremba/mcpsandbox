{
  "name": "@onemcp/widget-react",
  "version": "0.1.0",
  "description": "React AI chat widget with assistant-ui and MCP support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "build:standalone": "vite build --config vite.standalone.config.ts",
    "build:all": "pnpm build && pnpm build:standalone",
    "dev": "vite build --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai-sdk",
    "assistant-ui",
    "chat-widget",
    "mcp",
    "react",
    "openai",
    "anthropic"
  ],
  "license": "MIT",
  "dependencies": {
    "@ai-sdk/anthropic": "2.0.41",
    "@ai-sdk/openai": "2.0.64",
    "@ai-sdk/provider": "^2.0.0",
    "@assistant-ui/react": "0.11.47",
    "@assistant-ui/react-markdown": "^0.11.6",
    "@modelcontextprotocol/ext-apps": "0.1.0",
    "@onemcp/shared": "workspace:*",
    "ai": "^5.0.89",
    "mermaid": "^11.4.0",
    "react-shiki": "^0.3.0",
    "remark-gfm": "^4.0.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.1",
    "vite-plugin-css-injected-by-js": "3.5.2",
    "vite-plugin-dts": "^4.0.0"
  }
}
